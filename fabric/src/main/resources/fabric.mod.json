{
  "schemaVersion": 1,
  "id": "dungeontrain",
  "version": "${version}",
  "name": "Dungeon Train",
  "description": "A Minecraft port of Dungeon Train (brennanhatton.itch.io/dungeontrain) - a moving train that hosts procedurally generated dungeons.",
  "authors": ["Brennan Hatton"],
  "license": "PolyForm Shield 1.0.0",
  "environment": "*",
  "entrypoints": {
    "main": ["games.brennan.dungeontrain.fabric.DungeonTrainFabric"],
    "client": ["games.brennan.dungeontrain.fabric.client.DungeonTrainFabricClient"]
  },
  "mixins": [
    "dungeontrain.mixins.json",
    "dungeontrain.fabric.mixins.json",
    "dungeontrain.vivecraft.mixins.json"
  ],
  "accessWidener": "dungeontrain.accesswidener",
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "1.21.1",
    "sable": "*"
  },
  "suggests": {
    "adventureitemnames": "*",
    "adventureitemstats": "*",
    "playermob": "*",
    "discordpresence": "*",
    "enderchestpersistence": "*"
  }
}
